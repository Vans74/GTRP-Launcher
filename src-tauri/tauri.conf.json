{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GTRP Launcher",
  "version": "0.1.12",
  "identifier": "fr.gtrp.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GTRP Launcher",
        "width": 1040,
        "height": 640,
        "minWidth": 1040,
        "minHeight": 640,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["French"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCOTNGQTVFMEM0QjUwQzIKUldUQ1VFc01YdnFUVzBHbm5TY3pucFhUL3FiOFJ3Z0lmMFl1eHVWcUY4QmdFaGlNZExsQjNFRncK",
      "endpoints": [
        "https://github.com/Vans74/GTRP-Launcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
